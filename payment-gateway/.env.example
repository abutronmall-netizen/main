APP_NAME="FNB Gateway"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fnb_gateway
DB_USERNAME=root
DB_PASSWORD=

QUEUE_CONNECTION=database
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost
FRONTEND_URL=http://localhost:5173

FNB_BASE_URI=https://api.firstnationalbank.com/payments/v2
FNB_OAUTH_URI=https://api.firstnationalbank.com/oauth2/token
FNB_CLIENT_ID=your-client-id
FNB_CLIENT_SECRET=your-client-secret
FNB_CERT_PATH=
FNB_CERT_KEY_PATH=
FNB_WEBHOOK_SECRET=whsec_sample

FNB_WEBHOOK_VERIFICATION=strict
FNB_RUN_INTEGRATION_TESTS=false

BILLING_STATEMENT_EMAIL=finance@example.com
